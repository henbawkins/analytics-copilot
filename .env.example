# ─────────────────────────────────────────────────────────────
# Analytics Copilot — environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Anthropic (REQUIRED) -------------------------------------
# Your agency Anthropic API key. Billed once, serves the whole team.
ANTHROPIC_API_KEY=

# Model to use. Defaults to claude-opus-4-6 if unset.
# Set to claude-sonnet-4-6 for lower cost, or claude-haiku-4-5 for cheapest.
ANTHROPIC_MODEL=claude-opus-4-6

# --- Google service account (REQUIRED) ------------------------
# Absolute path to the GA4/GSC service-account JSON key.
# This one credential reaches every GA4 property + GSC site the
# account has been granted access to.
GOOGLE_APPLICATION_CREDENTIALS=/Users/benhawkins/.config/agency-analytics/ga4-gsc-key.json

# On serverless hosts (Vercel) there is no file on disk, so instead paste the
# service-account key here. Accepts raw JSON or base64-encoded JSON. When set,
# this takes precedence over GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_CREDENTIALS_JSON=

# --- Auth (REQUIRED for production / team access) -------------
# Google OAuth credentials — create at https://console.cloud.google.com/apis/credentials
# (OAuth 2.0 Client ID, type "Web application").
# Authorized redirect URI: <your-url>/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Random secret for NextAuth session encryption.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL of the app (http://localhost:3000 in dev).
NEXTAUTH_URL=http://localhost:3000

# Comma-separated list of team emails allowed to sign in.
# e.g. ben@agency.com,jane@agency.com
ALLOWED_EMAILS=

# Set to "true" to bypass auth during LOCAL development only.
# NEVER set this in production — it disables the login gate entirely.
DEV_AUTH_BYPASS=true
