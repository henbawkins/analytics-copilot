# ─────────────────────────────────────────────────────────────
# Analytics Copilot — environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Anthropic (REQUIRED) -------------------------------------
# Your agency Anthropic API key. Billed once, serves the whole team.
ANTHROPIC_API_KEY=

# Model to use. Defaults to claude-opus-4-6 if unset.
# Set to claude-sonnet-4-6 for lower cost, or claude-haiku-4-5 for cheapest.
ANTHROPIC_MODEL=claude-opus-4-6

# --- Google service account (REQUIRED) ------------------------
# Absolute path to the GA4/GSC service-account JSON key.
# This one credential reaches every GA4 property + GSC site the
# account has been granted access to.
GOOGLE_APPLICATION_CREDENTIALS=/Users/benhawkins/.config/agency-analytics/ga4-gsc-key.json

# On serverless hosts (Vercel) there is no file on disk, so instead paste the
# service-account key here. Accepts raw JSON or base64-encoded JSON. When set,
# this takes precedence over GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_CREDENTIALS_JSON=

# --- Auth (shared passcode gate) ------------------------------
# The single passcode the whole team enters to use the app.
APP_PASSWORD=

# Secret used to sign the session cookie. Generate with: openssl rand -base64 32
APP_SESSION_SECRET=

# Set to "true" to bypass the passcode during LOCAL development only.
# Leave false (or unset) in production so the gate is enforced.
DEV_AUTH_BYPASS=false
